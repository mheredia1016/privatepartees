---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Contact | PrivatePartees.com">
  <Header />
  <section class="subpage-hero small-hero">
    <img src="/images/hero/club-elmwood-hero.png" alt="Contact" />
    <div class="hero-shade"></div>
    <div class="subpage-copy reveal"><span>Contact</span><h1>Request Information</h1></div>
  </section>
  <section class="section contact-grid">
    <div class="contact-copy reveal">
      <span class="kicker">Start Planning</span>
      <h2>Tell us about your event.</h2>
      <p>Use this form to collect leads through Netlify Forms. Replace the email/phone once the company details are finalized.</p>
      <p><strong>Email:</strong> info@privatepartees.com<br /><strong>Phone:</strong> (000) 000-0000</p>
    </div>
    <form class="contact-form reveal" name="inquiry" method="POST" data-netlify="true">
      <input type="hidden" name="form-name" value="inquiry" />
      <label>Name<input name="name" required /></label>
      <label>Email<input type="email" name="email" required /></label>
      <label>Phone<input name="phone" /></label>
      <label>Venue<select name="venue"><option>Cielo</option><option>The Avenue</option><option>Club Elmwood Park</option><option>Not Sure Yet</option></select></label>
      <label>Message<textarea name="message" rows="6"></textarea></label>
      <button class="gold-button" type="submit">Send Inquiry</button>
    </form>
  </section>
  <Footer />
</BaseLayout>
