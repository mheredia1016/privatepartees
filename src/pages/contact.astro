---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Contact | PrivatePartees.com">
  <Header />
  <section class="subpage-hero small-hero">
    <img src="/images/hero/club-elmwood-hero.png" alt="Contact" />
    <div class="hero-shade"></div>
    <div class="subpage-copy reveal"><span>Contact</span><h1>Request Information</h1></div>
  </section>
  <center><section class="section contact-simple">

 <div class="section-heading">
    <span>Contact</span>
    <h1>Let's Plan Your Event</h1>
  </div>

  <div class="contact-card">

    <p>
      Have questions about pricing, availability, or scheduling a tour?
      Call or text us anytime.
    </p>

    <h2>
      <a href="tel:3126710777">(312) 671-0777</a>
    </h2>

    <div class="contact-buttons">
      <a href="tel:3126710777" class="gold-button">
        Call Now
      </a>

      <a href="sms:3126710777" class="gold-button">
        Send a Text
      </a>
    </div>

  </div>

</section></center>
  <Footer />
</BaseLayout>
