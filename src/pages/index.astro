---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSlider from '../components/HeroSlider.astro';
import VenueCards from '../components/VenueCards.astro';
import CTA from '../components/CTA.astro';
---
<BaseLayout title="PrivatePartees.com | Private Event Venues">
  <Header />
  <HeroSlider />
  <VenueCards />

  <section class="section split-section">
    <div class="split-image reveal"><img src="/images/hero/cielo-hero.png" alt="Banquet hall event setup" /></div>
    <div class="split-copy reveal">
      <span class="kicker">Private Events</span>
      <h2>Designed for weddings, birthdays, corporate events, quinceañeras, and unforgettable nights.</h2>
      <p>PrivatePartees.com brings together three distinct venues with elegant rooms, polished service, and photo-ready spaces for every celebration.</p>
      <div class="feature-list">
        <span>Weddings</span><span>Quinceañeras</span><span>Corporate Events</span><span>Birthday Parties</span><span>Baby Showers</span><span>Anniversaries</span>
      </div>
    </div>
  </section>

  <section class="section gallery-preview">
    <div class="section-heading reveal">
      <span>Gallery</span>
      <h2>Picture Your Event Here</h2>
    </div>
    <div class="masonry-grid reveal">
      <img src="/images/hero/cielo-hero.png" alt="Cielo" />
      <img src="/images/hero/avenue-hero.png" alt="The Avenue" />
      <img src="/images/hero/club-elmwood-hero.png" alt="Club Elmwood Park" />
      <img src="/images/hero/cielo-hero2.png" alt="Cielo" />
      <img src="/images/hero/club-elmwood-hero2.png" alt="Club Elmwood Park" />
    </div>
  </section>

  <section class="testimonial reveal">
    <p>“Elegant rooms, beautiful lighting, and a team that knows how to make private events feel special.”</p>
    <span>PrivatePartees.com</span>
  </section>

  <CTA />
  <Footer />
</BaseLayout>
